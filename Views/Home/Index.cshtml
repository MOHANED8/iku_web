@{
    ViewData["Title"] = "Home";
}

<div class="hero">
    <div class="hero-content text-center">
        <h1>Welcome to E-Shop!</h1>
        <p>Your one-stop shop for all your needs.</p>
        <a class="btn btn-primary" href="@Url.Action("Index", "Products")">Shop Now</a>
    </div>
</div>

<div class="features mt-5">
    <h2 class="text-center">Our Features</h2>
    <div class="row">
        <div class="col-md-4 feature-card">
            <h3>Fast Delivery</h3>
            <p>Get your orders delivered quickly and efficiently.</p>
        </div>
        <div class="col-md-4 feature-card">
            <h3>Quality Products</h3>
            <p>We offer only the best products for our customers.</p>
        </div>
        <div class="col-md-4 feature-card">
            <h3>24/7 Support</h3>
            <p>Our customer support is available round the clock.</p>
        </div>
    </div>
</div>
